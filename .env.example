# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Docker: REDIS_URL=redis://redis:6379

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
# Docker: MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=mcp_soc

# ── AWS ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=mcp-soc-raw-logs

# ── Firebase ──────────────────────────────────────────────────────
# Path to downloaded service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=config/firebase-service-account.json

# ── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SendGrid ──────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
ALERT_FROM_EMAIL=alerts@your-domain.com

# ── App URLs ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ── Correlation ───────────────────────────────────────────────────
CORRELATION_WINDOW_MINUTES=60

# ── Risk Score Multipliers ────────────────────────────────────────
RISK_PRIVILEGE_HIGH=2.0
RISK_PRIVILEGE_LOW=1.0
RISK_ASSET_CRITICAL=2.0
RISK_ASSET_LOW=1.0

# ── GeoIP ─────────────────────────────────────────────────────────
# Download from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
